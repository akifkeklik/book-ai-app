# ─────────────────────────────────────────────────────────────
# Book AI Backend – Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────

# Flask
DEBUG=False
SECRET_KEY=replace-with-a-long-random-string

# Google Books API  (see docs/google_api_setup.md)
GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here

# Supabase  (see docs/supabase_setup.md)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ML
TOP_N_RECOMMENDATIONS=10

# CORS – comma-separated origins, or * for any
ALLOWED_ORIGINS=*
